# SRS (Simple Realtime Server) configuration
# Supports: RTMP, SRT, RTSP, HLS, WebRTC ingest
# Install: https://ossrs.io
#
# Stream key = channel slug
# RTMP push:  rtmp://server:1935/live/{slug}
# SRT push:   srt://server:10080?streamid=#!::r=live/{slug},m=publish
# RTSP push:  rtsp://server:8554/live/{slug}

listen              1935;
max_connections     1000;
daemon              off;
srs_log_tank        console;

http_api {
    enabled         on;
    listen          1985;
}

http_server {
    enabled         on;
    listen          8080;
    dir             ./objs/nginx/html;
}

# ── SRT ingest (port 10080) ───────────────────────────────────────────────────
srt_server {
    enabled     on;
    listen      10080;
    maxbw       -1;
    connect_timeout 4000;
    peerlatency 0;
    recvlatency 120;
}

# ── RTSP ingest (port 8554) ───────────────────────────────────────────────────
rtc_server {
    enabled on;
    listen  8000;
    candidate $CANDIDATE;
}

vhost __defaultVhost__ {

    # Notify Laravel on publish/unpublish
    http_hooks {
        enabled         on;
        on_publish      http://127.0.0.1/api/streams/start;
        on_unpublish    http://127.0.0.1/api/streams/stop;
    }

    # HLS output (Laravel also generates its own via FFmpeg)
    hls {
        enabled         on;
        hls_path        /var/www/mediaserver/storage/streams;
        hls_fragment    2;
        hls_window      10;
    }

    # RTSP ingest
    rtsp {
        enabled     on;
        listen      8554;
    }
}
