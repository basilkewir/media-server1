APP_NAME="MediaServer"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_PORT=8080
APP_VERSION=1.1.0

LOG_CHANNEL=daily
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=media_server
DB_USERNAME=media_user
DB_PASSWORD=

CACHE_DRIVER=redis
CACHE_PREFIX=mediaserver

QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_LOG_LEVEL=warning

# HLS Output
HLS_SEGMENT_DURATION=2
HLS_SEGMENTS_IN_PLAYLIST=10

# Stream Settings
STREAM_SOURCE_TIMEOUT=5
STREAM_VOD_FALLBACK_ENABLED=true
STREAM_HEALTH_CHECK_INTERVAL=5
STREAM_PIPE_ENABLED=true

# Icecast2 — must run on the same server (localhost)
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=
ICECAST_MAX_LISTENERS_PER_STREAM=1000
ICECAST_CONF_DIR=/etc/icecast2/mounts

# RTMP
RTMP_HOST=localhost
RTMP_PORT=1935

# Media Server Driver: ffmpeg (built-in) | wowza | flussonic
MEDIA_SERVER_DRIVER=ffmpeg

# Wowza Streaming Engine (set MEDIA_SERVER_DRIVER=wowza to use)
WOWZA_URL=http://localhost:8087
WOWZA_USERNAME=admin
WOWZA_PASSWORD=
WOWZA_APPLICATION=live

# Flussonic Media Server (set MEDIA_SERVER_DRIVER=flussonic to use)
FLUSSONIC_URL=http://localhost:8080
FLUSSONIC_USERNAME=admin
FLUSSONIC_PASSWORD=

# API Security
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_MINUTE_AUTHENTICATED=120

# Webhook authentication: shared secret for RTMP/SRT callbacks (set to empty to disable)
WEBHOOK_SECRET=
